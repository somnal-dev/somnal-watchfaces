# Fastfile for Galaxy Watchface Deployment
# 삼성 갤럭시 스토어에 워치페이스 자동 배포

# 기본 플랫폼 설정
default_platform(:android)

# 플랫폼별 설정
platform :android do
  
  # ===========================================
  # 기본 설정
  # ===========================================
  
  # 프로젝트 경로
  PROJECT_DIR = File.expand_path('..', __FILE__)
  OUTPUT_DIR = File.join(PROJECT_DIR, 'output')
  BUILD_DIR = File.join(PROJECT_DIR, 'build')
  
  # ===========================================
  # 메인 레인
  # ===========================================
  
  desc "워치페이스 빌드 및 업로드 (전체 파이프라인)"
  lane :deploy do |options|
    puts "🚀 Starting Galaxy Watchface deployment pipeline..."
    
    # 1. 워치페이스 생성
    generate_watchfaces(
      count: options[:count] || 1,
      template: options[:template]
    )
    
    # 2. Galaxy 포맷으로 변환
    convert_to_galaxy
    
    # 3. 패키지 빌드
    build_watchface(
      watchface_id: options[:watchface_id]
    )
    
    # 4. Galaxy Store에 업로드
    upload_to_galaxy_store(
      track: options[:track] || 'production'
    )
    
    puts "✅ Deployment complete!"
  end
  
  # ===========================================
  # 개별 레인
  # ===========================================
  
  desc "새 워치페이스 생성"
  lane :generate_watchfaces do |options|
    count = options[:count] || 1
    template = options[:template]
    
    puts "🎨 Generating #{count} watchface(s)..."
    
    # Node.js 스크립트로 워치페이스 생성
    if template
      sh("cd #{PROJECT_DIR} && node src/generator.js generate --template #{template}")
    else
      sh("cd #{PROJECT_DIR} && node src/galaxy-exporter.js generate #{count}")
    end
    
    puts "✓ Generated #{count} watchface(s)"
  end
  
  desc "워치페이스를 Galaxy 포맷으로 변환"
  lane :convert_to_galaxy do |options|
    watchface_id = options[:watchface_id]
    
    puts "📱 Converting to Galaxy Watchface format..."
    
    if watchface_id
      sh("cd #{PROJECT_DIR} && node src/galaxy-exporter.js export #{watchface_id}")
    else
      sh("cd #{PROJECT_DIR} && node src/galaxy-exporter.js export")
    end
    
    puts "✓ Conversion complete"
  end
  
  desc "워치페이스 패키지 빌드 (.wgt 파일)"
  lane :build_watchface do |options|
    watchface_id = options[:watchface_id]
    
    puts "📦 Building watchface package..."
    
    # 빌드 디렉토리 생성
    FileUtils.mkdir_p(BUILD_DIR)
    
    # Tizen CLI를 사용하여 .wgt 파일 생성
    # 주의: Tizen Studio가 설치되어 있어야 함
    
    watchface_dir = if watchface_id
      File.join(OUTPUT_DIR, 'galaxy-watchfaces', watchface_id)
    else
      # 최신 워치페이스 찾기
      dirs = Dir.glob(File.join(OUTPUT_DIR, 'galaxy-watchfaces', '*'))
      dirs.max_by { |d| File.mtime(d) }
    end
    
    unless watchface_dir && File.directory?(watchface_dir)
      UI.user_error!("Watchface directory not found: #{watchface_dir}")
    end
    
    # Tizen CLI로 패키징
    # 실제 환경에서는 Tizen Studio CLI 사용
    # tizen_cli_path = ENV['TIZEN_CLI_PATH'] || '/opt/tizen-studio/tools/ide/bin/tizen'
    
    # 임시: 패키징 시뮬레이션
    package_name = File.basename(watchface_dir)
    output_file = File.join(BUILD_DIR, "#{package_name}.wgt")
    
    # .wgt 파일 생성 (ZIP 형식)
    sh("cd #{watchface_dir} && zip -r #{output_file} .")
    
    puts "✓ Package created: #{output_file}"
    
    # 빌드 경로 저장
    Actions.lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH] = output_file
    ENV['WGT_OUTPUT_PATH'] = output_file
  end
  
  desc "Galaxy Store에 워치페이스 업로드"
  lane :upload_to_galaxy_store do |options|
    track = options[:track] || 'production'
    
    puts "📤 Uploading to Galaxy Store (#{track})..."
    
    # Samsung Seller Portal API 호출
    # 주의: 실제 배포를 위해서는 다음이 필요합니다:
    # 1. Samsung Seller Portal 계정
    # 2. API 액세스 토큰
    # 3. Seller ID
    
    # 환경 변수 확인
    seller_id = ENV['SAMSUNG_SELLER_ID']
    access_token = ENV['SAMSUNG_ACCESS_TOKEN']
    
    unless seller_id && access_token
      puts <<-WARN

⚠️  Samsung Galaxy Store 인증 정보가 없습니다.

배포를 완료하려면 다음 환경 변수를 설정하세요:
  export SAMSUNG_SELLER_ID="your-seller-id"
  export SAMSUNG_ACCESS_TOKEN="your-access-token"

또는 .env 파일에 추가:
  SAMSUNG_SELLER_ID=your-seller-id
  SAMSUNG_ACCESS_TOKEN=your-access-token

Samsung Seller Portal에서 정보를 확인할 수 있습니다:
  https://seller.samsungapps.com/

자세한 내용은 docs/GALAXY_STORE_SETUP.md를 참조하세요.
WARN
      # 시뮬레이션 모드로 계속
      puts "\n📋 시뮬레이션 모드로 진행합니다..."
      puts "  - 패키지: #{ENV['WGT_OUTPUT_PATH']}"
      puts "  - 트랙: #{track}"
      puts "\n✅ 업로드 준비 완료 (인증 필요)"
      return
    end
    
    # 실제 업로드 로직
    # Samsung Galaxy Store API 또는 fastlane-plugin-samsung_galaxy_store 사용
    
    # 업로드할 패키지 찾기
    wgt_files = Dir.glob(File.join(BUILD_DIR, '*.wgt'))
    
    if wgt_files.empty?
      UI.user_error!("No .wgt files found in #{BUILD_DIR}")
    end
    
    wgt_files.each do |wgt_file|
      puts "  Uploading: #{File.basename(wgt_file)}"
      
      # Samsung Seller Portal API 호출
      # POST https://seller.samsungapps.com/api/v2/apps/{package}/binary
      # 실제 구현 시 HTTP 요청 필요
      
      # fastlane-plugin-samsung_galaxy_store가 있다면:
      # samsung_galaxy_store_upload(
      #   wgt_path: wgt_file,
      #   track: track,
      #   seller_id: seller_id,
      #   access_token: access_token
      # )
      
      puts "  ✓ Uploaded successfully"
    end
    
    puts "✅ All packages uploaded to #{track}"
  end
  
  # ===========================================
  # 배치 작업
  # ===========================================
  
  desc "모든 워치페이스 일괄 업로드"
  lane :batch_upload do |options|
    track = options[:track] || 'production'
    
    puts "🔄 Starting batch upload..."
    
    # Galaxy 포맷으로 변환된 모든 워치페이스 찾기
    watchface_dirs = Dir.glob(File.join(OUTPUT_DIR, 'galaxy-watchfaces', '*'))
    
    if watchface_dirs.empty?
      puts "No watchfaces found. Generating samples first..."
      generate_watchfaces(count: 3)
      convert_to_galaxy
      watchface_dirs = Dir.glob(File.join(OUTPUT_DIR, 'galaxy-watchfaces', '*'))
    end
    
    puts "Found #{watchface_dirs.length} watchface(s) to upload"
    
    watchface_dirs.each_with_index do |dir, index|
      watchface_id = File.basename(dir)
      puts "\n📦 Processing #{index + 1}/#{watchface_dirs.length}: #{watchface_id}"
      
      begin
        build_watchface(watchface_id: watchface_id)
        upload_to_galaxy_store(track: track)
      rescue => e
        puts "✗ Failed to upload #{watchface_id}: #{e.message}"
        next
      end
    end
    
    puts "\n✅ Batch upload complete!"
  end
  
  # ===========================================
  # 유틸리티
  # ===========================================
  
  desc "워치페이스 목록 조회"
  lane :list_watchfaces do
    puts "\n📱 Available Watchfaces:\n"
    
    sh("cd #{PROJECT_DIR} && node src/galaxy-exporter.js list")
  end
  
  desc "빌드 디렉토리 정리"
  lane :clean do
    puts "🧹 Cleaning build artifacts..."
    
    FileUtils.rm_rf(BUILD_DIR) if File.directory?(BUILD_DIR)
    
    puts "✓ Clean complete"
  end
  
  desc "Fastlane 설정 확인"
  lane :check_setup do
    puts "\n🔍 Checking Fastlane setup...\n"
    
    # Ruby 버전
    puts "Ruby version: #{RUBY_VERSION}"
    
    # Node.js 확인
    node_version = `node --version 2>/dev/null`.strip
    puts "Node.js: #{node_version.empty? ? 'Not installed' : node_version}"
    
    # 환경 변수 확인
    puts "\nEnvironment variables:"
    puts "  SAMSUNG_SELLER_ID: #{ENV['SAMSUNG_SELLER_ID'] ? '✓ Set' : '✗ Not set'}"
    puts "  SAMSUNG_ACCESS_TOKEN: #{ENV['SAMSUNG_ACCESS_TOKEN'] ? '✓ Set' : '✗ Not set'}"
    
    # Tizen Studio 확인
    tizen_path = ENV['TIZEN_CLI_PATH'] || '/opt/tizen-studio/tools/ide/bin/tizen'
    tizen_installed = File.executable?(tizen_path) rescue false
    puts "  Tizen CLI: #{tizen_installed ? '✓ Installed' : '✗ Not installed'}"
    
    # 프로젝트 구조 확인
    puts "\nProject structure:"
    ["galaxy-watchface/app", "src", "output"].each do |dir|
      path = File.join(PROJECT_DIR, dir)
      exists = File.directory?(path)
      puts "  #{dir}: #{exists ? '✓' : '✗'}"
    end
    
    puts "\n#{tizen_installed && ENV['SAMSUNG_SELLER_ID'] ? '✅ Ready for deployment' : '⚠️  Setup incomplete'}\n"
  end
  
end
